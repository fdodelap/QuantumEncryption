#Cell 5 - Encryption Function
def quantum_encrypt(text, gate_key, backend, max_chars=4):
    print("=" * 55)
    print("  QUANTUM ENCRYPTION on", backend.name)
    print("=" * 55)

    bits = []
    for char in text[:max_chars]:
        byte = ord(char)
        for i in range(7, -1, -1):
            bits.append((byte >> i) & 1)

    print(f"  Text    : \"{text[:max_chars]}\"")
    print(f"  Bits    : {''.join(map(str, bits))}")
    print(f"  Qubits  : {len(bits)}")
    print()

    circuits = []
    for bit in bits:
        qc = QuantumCircuit(1, 1)
        if bit == 1:
            qc.x(0)
        qc.barrier()
        for gate, _ in gate_key:
            if   gate == 'h': qc.h(0)
            elif gate == 'x': qc.x(0)
            elif gate == 'z': qc.z(0)
            elif gate == 's': qc.s(0)
            elif gate == 't': qc.t(0)
        qc.barrier()
        qc.measure(0, 0)
        circuits.append(qc)

    print(f"  Sending {len(circuits)} qubits to {backend.name}...")
    pm      = generate_preset_pass_manager(backend=backend, optimization_level=1)
    sampler = Sampler(backend)
    job     = sampler.run(pm.run(circuits), shots=3)
    print(f"  Job ID : {job.job_id()}")
    print(f"  Waiting...")

    start   = time.time()
    result  = job.result()
    elapsed = round(time.time() - start, 1)
    print(f"  Done in {elapsed}s on real quantum hardware!")
    print()

    encrypted_bits = []
    for pub_result in result:
        counts = pub_result.data.c.get_counts()
        encrypted_bits.append(int(max(counts, key=counts.get)))

    enc_str = ''.join(map(str, encrypted_bits))
    enc_hex = hex(int(enc_str, 2))

    print(f"  Original bits  : {''.join(map(str, bits))}")
    print(f"  Encrypted bits : {enc_str}")
    print(f"  Encrypted hex  : {enc_hex}")
    print()
    print(f"  Encryption complete! Job: {job.job_id()}")
    print("=" * 55)

    return encrypted_bits, bits, job.job_id()

print("✅ Encryption function ready!")

#Cell 6- Decryption function

def quantum_decrypt(encrypted_bits, gate_key, backend):
    print("=" * 55)
    print("  QUANTUM DECRYPTION on", backend.name)
    print("=" * 55)

    inverse_key = list(reversed(gate_key))

    circuits = []
    for bit in encrypted_bits:
        qc = QuantumCircuit(1, 1)
        if bit == 1:
            qc.x(0)
        qc.barrier()
        for gate, _ in inverse_key:
            if   gate == 'h': qc.h(0)
            elif gate == 'x': qc.x(0)
            elif gate == 'z': qc.z(0)
            elif gate == 's': qc.sdg(0)
            elif gate == 't': qc.tdg(0)
        qc.barrier()
        qc.measure(0, 0)
        circuits.append(qc)

    print(f"  Sending {len(circuits)} qubits to {backend.name}...")
    pm      = generate_preset_pass_manager(backend=backend, optimization_level=1)
    sampler = Sampler(backend)
    job     = sampler.run(pm.run(circuits), shots=3)
    print(f"  Job ID : {job.job_id()}")
    print(f"  Waiting...")

    start   = time.time()
    result  = job.result()
    elapsed = round(time.time() - start, 1)
    print(f"  Done in {elapsed}s!")
    print()

    decrypted_bits = []
    for pub_result in result:
        counts = pub_result.data.c.get_counts()
        decrypted_bits.append(int(max(counts, key=counts.get)))

    chars = []
    for i in range(0, len(decrypted_bits), 8):
        byte_bits = decrypted_bits[i:i+8]
        if len(byte_bits) == 8:
            val = int(''.join(map(str, byte_bits)), 2)
            chars.append(chr(val) if 32 <= val <= 126 else '?')

    decrypted_text = ''.join(chars)

    print(f"  Decrypted bits : {''.join(map(str, decrypted_bits))}")
    print(f"  Decrypted text : \"{decrypted_text}\"")
    print()
    print("  Decryption complete!")
    print("=" * 55)

    return decrypted_text

print("✅ Decryption function ready!")

